// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String   @id @default(cuid())
  name      String
  title     String
  bio       String
  imageUrl  String?
  cvUrl     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  category    String
  imageUrl    String
  description String
  link        String?
  isFeatured  Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id           String   @id @default(cuid())
  type         String   // "work" or "leadership"
  period       String
  title        String
  organization String
  description  String
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Certification {
  id           String   @id @default(cuid())
  year         String
  title        String
  organization String
  description  String
  fileUrl      String?
  isFeatured   Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AboutSection {
  id            String   @id @default(cuid())
  headline      String
  journeyTitle  String
  journeyText   String
  skills        String   // JSON array of skill tags e.g. ["Strategic Planning","Team Leadership"]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Stat {
  id        String   @id @default(cuid())
  value     Int
  suffix    String   @default("+")
  label     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
